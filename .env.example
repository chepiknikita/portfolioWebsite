# -----------------------------------------------
# Application
# -----------------------------------------------
NODE_ENV=production
PORT=3000

# -----------------------------------------------
# Database
# When running inside Docker, use the service name
# as hostname (e.g. "db"), not "localhost"
# -----------------------------------------------
DATABASE_URL=postgresql://<user>:<password>@db:5432/<dbname>

POSTGRES_DB_NAME=<dbname>
POSTGRES_USER=<user>
POSTGRES_PASSWORD=<password>

# -----------------------------------------------
# PGAdmin — development only (docker-compose.dev.yml)
# -----------------------------------------------
PGADMIN_EMAIL=<email>
PGADMIN_PASSWORD=<password>
